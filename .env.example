# SecureGate — Environment Variables
# Copy this file to .env.local and fill in your values

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/securegate"

# NextAuth.js – generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Base URL (http://localhost:3000 for local, your Vercel domain for production)
NEXTAUTH_URL="http://localhost:3000"

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY="re_..."

# Upstash Redis (rate limiting) — optional locally, required in production
# https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL="https://...upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"
